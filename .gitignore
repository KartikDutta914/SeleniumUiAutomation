# ============================================================
.env
.env.*
*.properties.local

# ============================================================
# Compiled class files & archives
# ============================================================
*.class
*.jar
*.war
*.ear

# ============================================================
# Temp / misc
# ============================================================
*.tmp
*.bak
*.swp
*.log
